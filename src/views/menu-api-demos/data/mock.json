                    {"label": "Setting", "faClass": "fa-solid fa-gear", "usage": "<Setting theme=\"outline\" />"},
                    {"label": "User", "faClass": "fa-solid fa-user", "usage": "<User theme=\"outline\" />"},
                    {"label": "Like", "faClass": "fa-solid fa-heart", "usage": "<Like theme=\"outline\" />"},
                    {"label": "Remind", "faClass": "fa-solid fa-bell", "usage": "<Remind theme=\"outline\" />"},
                    {"label": "Search", "faClass": "fa-solid fa-magnifying-glass", "usage": "<Search theme=\"outline\" />"},
                    {"label": "Rocket", "faClass": "fa-solid fa-rocket", "usage": "<Rocket theme=\"outline\" />"},
                    {"label": "Star", "faClass": "fa-solid fa-star", "usage": "<Star theme=\"outline\" />"},
                    {"label": "Flash", "faClass": "fa-solid fa-bolt", "usage": "<Flash theme=\"outline\" />"},
                    {"label": "Protect", "faClass": "fa-solid fa-shield", "usage": "<Protect theme=\"outline\" />"},
                    {"label": "Cloud", "faClass": "fa-solid fa-cloud", "usage": "<Cloud theme=\"outline\" />"},
                    {"label": "Code", "faClass": "fa-solid fa-code", "usage": "<Code theme=\"outline\" />"}
                ],
                "codeExample": "<template>\n  <Home theme=\"outline\" :size=\"24\" />\n  <Setting theme=\"outline\" :size=\"24\" />\n  <Like theme=\"filled\" :size=\"24\" fill=\"#ef4444\" />\n</template>\n\n<script setup>\nimport { Home, Setting, Like } from '@icon-park/vue-next'\n</script>"
            }
        ]
    }
]