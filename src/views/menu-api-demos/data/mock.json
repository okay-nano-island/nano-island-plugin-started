                "installCmds": ["npm install @iconify/vue"],
                "codeFile": "IconifyDemo.vue",
                "sampleIcons": [
                    {"label": "mdi:home", "faClass": "fa-solid fa-house", "usage": "<Icon icon=\"mdi:home\" />"},
                    {"label": "mdi:cog", "faClass": "fa-solid fa-gear", "usage": "<Icon icon=\"mdi:cog\" />"},
                    {"label": "mdi:account", "faClass": "fa-solid fa-user", "usage": "<Icon icon=\"mdi:account\" />"},
                    {"label": "mdi:heart", "faClass": "fa-solid fa-heart", "usage": "<Icon icon=\"mdi:heart\" />"},
                    {"label": "mdi:bell", "faClass": "fa-solid fa-bell", "usage": "<Icon icon=\"mdi:bell\" />"},
                    {"label": "mdi:magnify", "faClass": "fa-solid fa-magnifying-glass", "usage": "<Icon icon=\"mdi:magnify\" />"},
                    {"label": "mdi:rocket", "faClass": "fa-solid fa-rocket", "usage": "<Icon icon=\"mdi:rocket\" />"},
                    {"label": "mdi:star", "faClass": "fa-solid fa-star", "usage": "<Icon icon=\"mdi:star\" />"},
                    {"label": "carbon:flash", "faClass": "fa-solid fa-bolt", "usage": "<Icon icon=\"carbon:flash\" />"},
                    {"label": "carbon:security", "faClass": "fa-solid fa-shield", "usage": "<Icon icon=\"carbon:security\" />"},
                    {"label": "tabler:cloud", "faClass": "fa-solid fa-cloud", "usage": "<Icon icon=\"tabler:cloud\" />"},
                    {"label": "tabler:code", "faClass": "fa-solid fa-code", "usage": "<Icon icon=\"tabler:code\" />"}
                ],
                "codeExample": "<template>\n  <!-- Material Design Icons -->\n  <Icon icon=\"mdi:home\" :width=\"24\" />\n  <Icon icon=\"mdi:cog\" :width=\"24\" />\n\n  <!-- Carbon 图标集 -->\n  <Icon icon=\"carbon:flash\" :width=\"20\" color=\"#f97316\" />\n\n  <!-- Tabler 图标集 -->\n  <Icon icon=\"tabler:heart\" :width=\"32\" color=\"#ef4444\" />\n\n  <!-- Twemoji (表情) -->\n  <Icon icon=\"twemoji:rocket\" :width=\"24\" />\n\n  <!-- 自定义样式 -->\n  <Icon icon=\"mdi:account-circle\" :width=\"48\" class=\"text-blue-500\" />\n</template>\n\n<script setup>\nimport { Icon } from '@iconify/vue'\n</script>"
            },
            {
                "id": "iconpark",
                "name": "IconPark",
                "icon": "fa-solid fa-palette",
                "color": "#00c3a0",
                "package": "@icon-park/vue-next",
                "version": "1.4.2",
                "officialUrl": "https://iconpark.oceanengine.com",
                "npmUrl": "https://www.npmjs.com/package/@icon-park/vue-next",
                "iconCount": "2,400+",
